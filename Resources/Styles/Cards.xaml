<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <SolidColorBrush x:Key="UiPrimaryBrush" Color="#FF1A1A1A"/>
    <SolidColorBrush x:Key="UiSecondaryBrush" Color="#FF2A2A2A"/>
    <SolidColorBrush x:Key="UiTextBrush" Color="#FFFFFFFF"/>
    <SolidColorBrush x:Key="UiSubTextBrush" Color="#FFB0B0B0"/>
    <SolidColorBrush x:Key="UiBorderBrush" Color="#FF404040"/>
    <SolidColorBrush x:Key="UiCardBrush" Color="#FF0A0A0A"/>

    <Style x:Key="UiCardContainer" TargetType="Border">
        <Setter Property="Background" Value="{StaticResource UiSecondaryBrush}"/>
        <Setter Property="CornerRadius" Value="8"/>
        <Setter Property="Padding" Value="15"/>
    </Style>
</ResourceDictionary>
