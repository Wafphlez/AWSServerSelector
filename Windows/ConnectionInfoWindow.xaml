<Window x:Class="AWSServerSelector.ConnectionInfoWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:AWSServerSelector"
        xmlns:controls="clr-namespace:AWSServerSelector.Controls"
        mc:Ignorable="d"
        Title="{x:Static local:LocalizationManager.ConnectionInfoTitle}"
        Height="750" Width="500"
        MinHeight="400" MinWidth="500"
        WindowStartupLocation="Manual"
        ShowInTaskbar="True"
        Background="#FF0A0A0A"
        FontFamily="Segoe UI Variable"
        Icon="../Resources/icon.ico"
        Style="{StaticResource CustomWindowStyle}">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0"
                Background="#FFDC143C"
                Padding="25,20"
                Margin="15,15,15,0">
            <StackPanel>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                    <TextBlock Text="🌐" FontSize="24" Foreground="White"/>
                    <TextBlock Text="{x:Static local:LocalizationManager.ConnectionInfoHeader}" FontSize="24" FontWeight="Bold" Foreground="White"/>
                </StackPanel>
                <TextBlock Text="{x:Static local:LocalizationManager.ConnectionInfoDescription}"
                          FontSize="14"
                          Foreground="#FFE0E0E0"
                          HorizontalAlignment="Center"
                          Margin="0,8,0,0"/>
            </StackPanel>
        </Border>

        <Border Grid.Row="1"
                Background="{StaticResource UiCardBrush}"
                BorderBrush="{StaticResource UiBorderBrush}"
                BorderThickness="1"
                Margin="15"
                CornerRadius="12">
            <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                <StackPanel Margin="20">

                    <controls:ConnectionCardControl Icon="🏠"
                                                    HeaderText="{x:Static local:LocalizationManager.LobbyConnectionStatus}"
                                                    StatusLabel="{x:Static local:LocalizationManager.Status}"
                                                    StatusText="{Binding LobbyStatusText}"
                                                    StatusForeground="{Binding LobbyStatusForeground}"
                                                    IpLabel="{x:Static local:LocalizationManager.IPPort}"
                                                    IpText="{Binding LobbyIpText}"
                                                    IpCopyButtonVisibility="{Binding LobbyCopyVisibility}"
                                                    CopyToolTip="Копировать IP:Порт лобби"
                                                    CopyIpClicked="CopyLobbyIpButton_Click"
                                                    ServerLabel="{x:Static local:LocalizationManager.Server}"
                                                    ServerText="{Binding LobbyServerText}"
                                                    PingLabel="{x:Static local:LocalizationManager.Ping}"
                                                    PingText="{Binding LobbyPingText}"
                                                    PingForeground="{Binding LobbyPingForeground}"
                                                    RegionLabel="{x:Static local:LocalizationManager.Region}"
                                                    RegionText="{Binding LobbyRegionText}"/>

                    <controls:ConnectionCardControl Icon="🎮"
                                                    HeaderText="{x:Static local:LocalizationManager.MatchConnectionStatus}"
                                                    StatusLabel="{x:Static local:LocalizationManager.Status}"
                                                    StatusText="{Binding GameStatusText}"
                                                    StatusForeground="{Binding GameStatusForeground}"
                                                    IpLabel="{x:Static local:LocalizationManager.IPPort}"
                                                    IpText="{Binding GameIpText}"
                                                    IpCopyButtonVisibility="{Binding GameCopyVisibility}"
                                                    CopyToolTip="Копировать IP:Порт матча"
                                                    CopyIpClicked="CopyGameIpButton_Click"
                                                    ServerLabel="{x:Static local:LocalizationManager.Server}"
                                                    ServerText="{Binding GameServerText}"
                                                    PingLabel="{x:Static local:LocalizationManager.Ping}"
                                                    PingText="{Binding GamePingText}"
                                                    PingForeground="{Binding GamePingForeground}"
                                                    RegionLabel="{x:Static local:LocalizationManager.Region}"
                                                    RegionText="{Binding GameRegionText}"/>

                    <Border Style="{StaticResource UiCardContainer}" Margin="0,0,0,15">
                        <StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                                <TextBlock Text="🕒" FontSize="16" Foreground="White"/>
                                <TextBlock Text="{x:Static local:LocalizationManager.LastUpdate}" FontSize="16" FontWeight="SemiBold" Foreground="White"/>
                            </StackPanel>
                            <TextBlock Text="{Binding LastUpdateText, FallbackValue={x:Static local:LocalizationManager.Initializing}}"
                                      Foreground="{Binding LastUpdateForeground}"
                                      FontWeight="SemiBold"/>
                        </StackPanel>
                    </Border>

                    <Border Style="{StaticResource UiCardContainer}">
                        <StackPanel>
                            <TextBlock FontSize="16" FontWeight="SemiBold" Foreground="White" Margin="0,0,0,10">
                                <Run Text="💡 "/><Run Text="{x:Static local:LocalizationManager.Instructions}"/>
                            </TextBlock>
                            <TextBlock Text="{x:Static local:LocalizationManager.InstructionsText}"
                                      TextWrapping="Wrap"
                                      Foreground="#FFB0B0B0"
                                      FontSize="13"
                                      LineHeight="18"/>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </ScrollViewer>
        </Border>

        <controls:DialogActionBarControl Grid.Row="2"
                                         SecondaryButtonText="{x:Static local:LocalizationManager.Refresh}"
                                         SecondaryClick="RefreshButton_Click"
                                         PrimaryButtonText="{x:Static local:LocalizationManager.Close}"
                                         PrimaryClick="CloseButton_Click"/>
    </Grid>
</Window>
