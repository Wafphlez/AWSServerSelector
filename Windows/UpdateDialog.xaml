<Window x:Class="AWSServerSelector.UpdateDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:controls="clr-namespace:AWSServerSelector.Controls"
        Title="Проверить обновления" 
        Width="400" 
        Height="270"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="#0A0A0A"
        FontFamily="Segoe UI Variable"
        Icon="../Resources/icon.ico"
        Style="{StaticResource CustomWindowStyle}"
        TextOptions.TextFormattingMode="Ideal"
        TextOptions.TextRenderingMode="Aliased"
        RenderOptions.BitmapScalingMode="NearestNeighbor"
        RenderOptions.EdgeMode="Aliased"
        SnapsToDevicePixels="True"
        UseLayoutRounding="True">
    
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        
        <!-- Content -->
        <StackPanel Grid.Row="0" Margin="25">
            <!-- Title -->
            <TextBlock Text="Проверка обновлений"
                       FontSize="18"
                       FontWeight="Bold"
                       Foreground="White"
                       Margin="0,0,0,10"/>
            
            <!-- Version Info -->
            <StackPanel Margin="0,0,0,10">
                <TextBlock Text="{Binding YourVersionText}"
                           FontSize="12"
                           Foreground="LightGray"
                           Margin="0,0,0,5"/>
                
                <TextBlock Text="{Binding LatestVersionText}"
                           FontSize="12"
                           Foreground="LightGray"
                           Margin="0,0,0,5"/>
            </StackPanel>
            
            <!-- Status -->
            <TextBlock Text="{Binding StatusText}"
                       FontSize="12"
                       Foreground="LightGray"
                       Margin="0,0,0,10"
                       TextWrapping="Wrap"/>
            
            <!-- Update Info (visible when update is available) -->
            <StackPanel x:Name="UpdateInfoPanel" Visibility="{Binding UpdateInfoVisibility}" Margin="0,0,0,10">
                <TextBlock Text="{Binding UpdateTitle}"
                           FontSize="14"
                           FontWeight="Bold"
                           Foreground="#FF28A745"
                           Margin="0,0,0,5"/>
                
                <TextBlock Text="{Binding UpdateDescription}"
                           FontSize="11"
                           Foreground="LightGray"
                           TextWrapping="Wrap"
                           Margin="0,0,0,10"/>
                
                <TextBlock Text="{Binding UpdateSize}"
                           FontSize="10"
                           Foreground="Gray"
                           Margin="0,0,0,5"/>
            </StackPanel>
        </StackPanel>
        
        <controls:DialogActionBarControl Grid.Row="1"
                                         x:Name="DialogActionBar"
                                         SecondaryButtonText="Скачать обновление"
                                         SecondaryButtonWidth="150"
                                         SecondaryButtonVisibility="{Binding DownloadButtonVisibility}"
                                         PrimaryButtonText="Закрыть"
                                         PrimaryButtonWidth="100"
                                         ButtonHeight="30"
                                         SecondaryClick="DownloadButton_Click"
                                         PrimaryClick="CloseButton_Click"/>
    </Grid>
</Window>

