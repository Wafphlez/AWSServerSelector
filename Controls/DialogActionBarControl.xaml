<UserControl x:Class="AWSServerSelector.Controls.DialogActionBarControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Name="Root">
    <Border Style="{StaticResource UiDialogFooterBorder}">
        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="{Binding SecondaryButtonText, ElementName=Root}"
                    MinWidth="{Binding SecondaryButtonWidth, ElementName=Root}"
                    Width="Auto"
                    MinHeight="{Binding ButtonHeight, ElementName=Root}"
                    Padding="18,8"
                    VerticalContentAlignment="Center"
                    Margin="0,0,10,0"
                    Visibility="{Binding SecondaryButtonVisibility, ElementName=Root}"
                    Style="{StaticResource UiSecondaryButton}"
                    Click="SecondaryButton_Click"/>
            <Button Content="{Binding PrimaryButtonText, ElementName=Root}"
                    MinWidth="{Binding PrimaryButtonWidth, ElementName=Root}"
                    Width="Auto"
                    MinHeight="{Binding ButtonHeight, ElementName=Root}"
                    Padding="18,8"
                    VerticalContentAlignment="Center"
                    Visibility="{Binding PrimaryButtonVisibility, ElementName=Root}"
                    Style="{StaticResource UiModernButton}"
                    Click="PrimaryButton_Click"/>
        </StackPanel>
    </Border>
</UserControl>
